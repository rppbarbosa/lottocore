# Copie para `.env` na VPS (nunca commite o arquivo real).
# DATABASE_URL deve usar o hostname do serviço Docker: `postgres`

POSTGRES_USER=bingo
POSTGRES_PASSWORD=altere_para_password_forte
POSTGRES_DB=bingo

# Obrigatório: mesmo user/password/db que acima; host = nome do serviço no Compose
DATABASE_URL=postgresql://bingo:altere_para_password_forte@postgres:5432/bingo

# API dentro da rede Docker
PORT=3000
NODE_ENV=production

# Mínimo ~32 caracteres aleatórios
JWT_SECRET=gerar_com_openssl_rand_base64_48

# Hostname servido pelo Traefik (mesmo valor no DNS A/AAAA → IP da VPS). Sem barra, sem https://
APP_HOST=lottocore.atus.tech

# URL pública (QR, PDF, links públicos). Sem barra final.
PUBLIC_APP_URL=https://lottocore.atus.tech

# Rede Docker onde o Traefik escuta (Hostinger / stack root: costuma ser root_default)
TRAEFIK_NETWORK=root_default

# Certificado TLS: Traefik usa mytlschallenge no /root/docker-compose.yml;
# com file provider: hostname em deploy/traefik/lottocore-http.yaml. E-mail ACME: SSL_EMAIL no /root/.env

# Portas publicadas no host (padrão na VPS). Com overlay docker-compose.traefik.yml estas podem não ser usadas para HTTP público.
PUBLISH_FRONTEND_PORT=8092
PUBLISH_BACKEND_PORT=3020
PUBLISH_POSTGRES_PORT=5440

# --- Opcional: overlay Compose com Host(DOMAIN) (mesma IP que Comissão 360 / outros) ---
# Descomente e alinhe a PUBLIC_APP_URL ao mesmo FQDN se usar:
# DOMAIN=lottocore.atus.tech
# HTTP_PORT=8080
# docker compose -f docker-compose.yml -f docker-compose.traefik.yml up -d --build
# ou: ./scripts/deploy-vps-traefik.sh

# --- VPS (stack "lottocore") ---
# docker network create root_default 2>/dev/null || true
# ./scripts/deploy-vps.sh  (cria volumes lottocore_pgdata / lottocore_uploads se necessário)
