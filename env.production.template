# Copie para `.env` na VPS (nunca commite o arquivo real).
# DATABASE_URL deve usar o hostname do serviço Docker: `postgres`

POSTGRES_USER=bingo
POSTGRES_PASSWORD=altere_para_password_forte
POSTGRES_DB=bingo

# Obrigatório: mesmo user/password/db que acima; host = nome do serviço no Compose
DATABASE_URL=postgresql://bingo:altere_para_password_forte@postgres:5432/bingo

# API dentro da rede Docker
PORT=3000
NODE_ENV=production

# Mínimo ~32 caracteres aleatórios
JWT_SECRET=gerar_com_openssl_rand_base64_48

# URL pública onde o jogador abre o site (HTTPS em produção). Sem barra final.
PUBLIC_APP_URL=https://bingo.seudominio.com

# --- Traefik (mesma VPS que Comissão 360, Nexus, etc.) ---
# Domínio só deste app (registro A/AAAA apontando para o IP da VPS). Tem de ser diferente do Comissão 360.
DOMAIN=bingo.seudominio.com
# Com Traefik: use docker compose -f docker-compose.yml -f docker-compose.traefik.yml (ou ./scripts/deploy-vps-traefik.sh).
# PUBLIC_APP_URL deve usar o mesmo host que DOMAIN (https).

# Porta no host do Nginx (só quando NÃO usa overlay Traefik; com Traefik o overlay zera isto)
HTTP_PORT=8080
