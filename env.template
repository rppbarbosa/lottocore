# Copie para .env na raiz (Docker Compose usa estes valores por padrão)

POSTGRES_USER=bingo
POSTGRES_PASSWORD=bingo_dev_change_me
POSTGRES_DB=bingo
POSTGRES_PORT=5433

# Backend (porta do host = POSTGRES_PORT acima quando usa Docker Compose)
DATABASE_URL=postgresql://bingo:bingo_dev_change_me@127.0.0.1:5433/bingo

PORT=3003
NODE_ENV=development

# Segredo HS256 para JWT do painel (obrigatório em produção; min. 32 caracteres recomendado)
JWT_SECRET=dev_jwt_secret_altere_em_producao_min_32_chars!!

# URL pública do frontend (QR no PDF e consistência com /c/{token})
PUBLIC_APP_URL=http://localhost:5173

# --- Produção (Docker na VPS) ---
# Ver env.production.template e docs/DEPLOY.md — use DATABASE_URL com host `postgres` no Compose.
